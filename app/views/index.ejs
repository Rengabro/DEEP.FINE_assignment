<!doctype html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
<main id="map_div" aria-label="POI 지도"></main>

<section class="panel" aria-label="POI 검색 및 관리">
    <div class="search-row">
        <label class="sr-only" for="poi-search">POI 검색</label>
        <input id="poi-search" type="search" placeholder="장소명을 검색하세요" autocomplete="off">
        <button id="search-button" type="button">검색</button>
    </div>
    <p id="poi-count" class="muted">POI를 불러오는 중입니다.</p>
    <ul id="poi-list" class="poi-list" aria-live="polite"></ul>
</section>

<div class="map-actions">
    <button id="add-poi-button" type="button" title="POI 추가 위치를 선택합니다">＋ <span>POI 추가</span></button>
    <button id="my-location-button" type="button" title="현재 위치로 이동합니다">◎ <span>내 위치</span></button>
    <button id="refresh-button" type="button" title="DB에서 POI를 다시 불러옵니다">↻ <span>새로고침</span></button>
    <button id="import-button" type="button" title="엑셀 파일을 업로드합니다">↑ <span>엑셀 Import</span></button>
    <input id="file-input" type="file" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" hidden>
</div>
<section id="import-preview" class="import-preview" hidden aria-live="polite">
    <strong id="import-file-name"></strong>
    <p id="import-row-count"></p>
    <div class="import-preview-actions">
        <button id="import-confirm-button" type="button">DB에 저장</button>
        <button id="import-cancel-button" type="button" class="secondary-button">취소</button>
    </div>
</section>
<aside id="route-panel" class="route-panel" hidden aria-label="TMAP 도보 경로 안내">
    <div class="route-panel-header">
        <strong>도보 경로 안내</strong>
        <button id="route-close-button" type="button" aria-label="경로 안내 닫기">×</button>
    </div>
    <p id="route-summary" class="route-summary"></p>
    <ol id="route-steps" class="route-steps"></ol>
</aside>
<div id="toast" class="toast" role="status" aria-live="polite"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(() => {
    const DEFAULT_CENTER = [37.5295, 126.9655];
    const map = L.map('map_div', { zoomControl: false }).setView(DEFAULT_CENTER, 15);
    L.control.zoom({ position: 'bottomright' }).addTo(map);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    const icons = {
        user: L.icon({ iconUrl: '/images/pin-red.svg', iconSize: [38, 45], iconAnchor: [19, 43], popupAnchor: [0, -40] }),
        poi: L.icon({ iconUrl: '/images/pin-location.svg', iconSize: [36, 43], iconAnchor: [18, 41], popupAnchor: [0, -38] })
    };
    const poiLayer = L.featureGroup().addTo(map);
    let routeLayer;
    let userMarker;
    let currentPosition;
    let pois = [];
    let firstPosition = true;
    let selectedPoiId = null;
    let selectedImportFile = null;
    let isPoiAddMode = false;

    const $ = (selector) => document.querySelector(selector);
    const notify = (message, isError = false) => {
        const toast = $('#toast');
        toast.textContent = message;
        toast.classList.toggle('error', isError);
        toast.classList.add('show');
        clearTimeout(notify.timer);
        notify.timer = setTimeout(() => toast.classList.remove('show'), 3500);
    };
    const request = async (url, options) => {
        const response = await fetch(url, options);
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
            const error = new Error(data.message || '요청에 실패했습니다.');
            error.invalidRows = data.invalidRows;
            throw error;
        }
        return data;
    };
    const setImportBusy = (isBusy) => {
        $('#import-button').disabled = isBusy;
        $('#import-confirm-button').disabled = isBusy;
        $('#import-cancel-button').disabled = isBusy;
    };
    const clearImportPreview = () => {
        selectedImportFile = null;
        $('#import-preview').hidden = true;
    };
    const showImportPreview = (file, validCount) => {
        $('#import-file-name').textContent = file.name;
        $('#import-row-count').textContent = `${validCount}건의 POI를 저장할 준비가 되었습니다.`;
        $('#import-preview').hidden = false;
    };
    const setPoiAddMode = (enabled) => {
        isPoiAddMode = enabled;
        $('#map_div').classList.toggle('is-adding-poi', enabled);
        $('#add-poi-button').classList.toggle('is-active', enabled);
        $('#add-poi-button').setAttribute('aria-pressed', String(enabled));
    };
    const makePopup = (poi, address = '') => {
        const content = document.createElement('div');
        const title = document.createElement('strong');
        title.textContent = poi.title;
        const coordinates = document.createElement('p');
        coordinates.textContent = `${Number(poi.latitude).toFixed(6)}, ${Number(poi.longitude).toFixed(6)}`;
        content.append(title, coordinates);
        if (address) {
            const addressLine = document.createElement('p');
            addressLine.textContent = address;
            content.append(addressLine);
        }
        if (currentPosition) {
            const routeButton = document.createElement('button');
            routeButton.type = 'button';
            routeButton.textContent = 'TMAP 도보 경로 보기';
            routeButton.addEventListener('click', () => drawRoute(poi));
            content.append(routeButton);
        }
        return content;
    };
    const renderList = (items) => {
        const list = $('#poi-list');
        list.replaceChildren();
        items.forEach((poi) => {
            const item = document.createElement('li');
            const titleButton = document.createElement('button');
            titleButton.type = 'button';
            titleButton.className = 'poi-title-button';
            titleButton.textContent = poi.title;
            titleButton.addEventListener('click', () => selectPoi(poi));
            const deleteButton = document.createElement('button');
            deleteButton.type = 'button';
            deleteButton.className = 'poi-delete-button';
            deleteButton.textContent = '×';
            deleteButton.setAttribute('aria-label', `${poi.title} 삭제`);
            deleteButton.title = '삭제';
            deleteButton.addEventListener('click', () => deletePoi(poi));
            item.append(titleButton, deleteButton);
            list.append(item);
        });
        $('#poi-count').textContent = `${items.length}개의 POI`;
    };
    const filterPois = () => {
        const keyword = $('#poi-search').value.trim().toLocaleLowerCase();
        renderList(keyword ? pois.filter((poi) => poi.title.toLocaleLowerCase().includes(keyword)) : pois);
    };
    const getAddress = async (latitude, longitude) => {
        try {
            const result = await request(`/api/tmap/reverse-geocoding?latitude=${latitude}&longitude=${longitude}`);
            return result.resultData?.addressInfo?.fullAddress || result.resultData?.addressInfo?.roadAddress || '';
        } catch (_) {
            return '';
        }
    };
    async function createPoiAt(latitude, longitude) {
        const title = window.prompt('추가할 POI 이름을 입력해 주세요.');
        if (title === null) return;

        try {
            const result = await request('/api/pois', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, latitude, longitude })
            });
            await loadPois();
            const createdPoi = pois.find((poi) => String(poi.id) === String(result.resultData.id));
            if (createdPoi) selectPoi(createdPoi);
            notify(result.message);
        } catch (error) {
            notify(error.message, true);
        }
    }
    async function deletePoi(poi) {
        if (!window.confirm(`'${poi.title}' POI를 삭제할까요?`)) return;

        try {
            const result = await request(`/api/pois/${poi.id}`, { method: 'DELETE' });
            if (String(selectedPoiId) === String(poi.id)) {
                selectedPoiId = null;
                map.closePopup();
            }
            await loadPois();
            notify(result.message);
        } catch (error) {
            notify(error.message, true);
        }
    }
    const getRouteInstructions = (route) => route.features
        .filter((feature) => feature.geometry?.type === 'Point')
        .map((feature) => feature.properties?.description)
        .filter((description, index, instructions) => description && instructions.indexOf(description) === index);
    const showRouteDetails = (route) => {
        const summary = route.features?.find((feature) => feature.properties?.totalDistance)?.properties;
        const instructions = getRouteInstructions(route);
        const list = $('#route-steps');
        list.replaceChildren();
        instructions.forEach((instruction) => {
            const item = document.createElement('li');
            item.textContent = instruction;
            list.append(item);
        });
        $('#route-summary').textContent = summary?.totalDistance
            ? `${Math.round(summary.totalDistance)}m · 약 ${Math.ceil(summary.totalTime / 60)}분`
            : 'TMAP 도보 경로';
        $('#route-panel').hidden = false;
    };
    async function selectPoi(poi) {
        selectedPoiId = poi.id;
        map.setView([poi.latitude, poi.longitude], Math.max(map.getZoom(), 17), { animate: true });
        const popup = poi.marker.getPopup();
        popup.setContent(makePopup(poi, '주소를 확인하는 중입니다.'));
        poi.marker.openPopup();
        const address = await getAddress(poi.latitude, poi.longitude);
        if (selectedPoiId === poi.id) {
            popup.setContent(makePopup(poi, address));
            poi.marker.openPopup();
        }
    }
    async function drawRoute(poi) {
        if (!currentPosition) return notify('현재 위치를 확인한 후 경로를 안내할 수 있습니다.', true);
        try {
            const routeResponse = await request('/api/tmap/pedestrian-route', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    startLat: currentPosition.lat, startLng: currentPosition.lng,
                    endLat: poi.latitude, endLng: poi.longitude, endName: poi.title
                })
            });
            const route = routeResponse.resultData;
            if (routeLayer) map.removeLayer(routeLayer);
            routeLayer = L.geoJSON(route, {
                filter: (feature) => feature.geometry?.type !== 'Point',
                style: { color: '#2478ff', weight: 5, opacity: .85 }
            }).addTo(map);
            if (routeLayer.getLayers().length) map.fitBounds(routeLayer.getBounds(), { padding: [40, 40] });
            showRouteDetails(route);
            const summary = route.features?.find((feature) => feature.properties?.totalDistance)?.properties;
            notify(summary?.totalDistance
                ? `도보 ${Math.round(summary.totalDistance)}m · 약 ${Math.ceil(summary.totalTime / 60)}분`
                : 'TMAP 도보 경로를 표시했습니다.');
        } catch (error) {
            notify(error.message, true);
        }
    }
    async function loadPois() {
        try {
            const data = await request('/api/pois');
            poiLayer.clearLayers();
            pois = data.resultData.map((poi) => {
                poi.latitude = Number(poi.latitude);
                poi.longitude = Number(poi.longitude);
                poi.marker = L.marker([poi.latitude, poi.longitude], { icon: icons.poi, title: poi.title })
                    .bindPopup(L.popup({ maxWidth: 260, autoPan: false }));
                // Run after Leaflet's built-in popup toggle so a reselected marker always opens.
                poi.marker.on('click', () => setTimeout(() => selectPoi(poi), 0));
                poi.marker.addTo(poiLayer);
                return poi;
            });
            filterPois();
            if (!currentPosition && pois.length) map.fitBounds(poiLayer.getBounds(), { padding: [40, 40], maxZoom: 16 });
        } catch (error) {
            $('#poi-count').textContent = 'POI를 불러오지 못했습니다.';
            notify(error.message, true);
        }
    }
    function trackPosition() {
        if (!navigator.geolocation) return notify('이 브라우저는 위치 추적을 지원하지 않습니다.', true);
        navigator.geolocation.watchPosition((position) => {
            currentPosition = { lat: position.coords.latitude, lng: position.coords.longitude };
            const point = [currentPosition.lat, currentPosition.lng];
            if (!userMarker) userMarker = L.marker(point, { icon: icons.user, zIndexOffset: 1000 }).addTo(map).bindPopup('현재 위치');
            else userMarker.setLatLng(point);
            if (firstPosition) {
                map.setView(point, 16);
                firstPosition = false;
            }
        }, () => notify('위치 권한을 허용하면 현재 위치와 경로를 안내합니다.', true), {
            enableHighAccuracy: true, maximumAge: 5000, timeout: 10000
        });
    }

    $('#poi-search').addEventListener('input', filterPois);
    $('#search-button').addEventListener('click', filterPois);
    $('#add-poi-button').addEventListener('click', () => {
        const willEnable = !isPoiAddMode;
        setPoiAddMode(willEnable);
        if (willEnable) notify('지도에서 POI를 추가할 위치를 클릭해 주세요.');
    });
    $('#my-location-button').addEventListener('click', () => {
        if (!userMarker) {
            notify('현재 위치를 확인하는 중입니다. 위치 권한을 허용해 주세요.', true);
            return;
        }
        // Use the rendered marker position so the map always centers on the red pin itself.
        map.setView(userMarker.getLatLng(), 16, { animate: true });
    });
    $('#route-close-button').addEventListener('click', () => {
        $('#route-panel').hidden = true;
        if (routeLayer) {
            map.removeLayer(routeLayer);
            routeLayer = undefined;
        }
    });
    $('#refresh-button').addEventListener('click', async () => {
        await loadPois();
        notify('DB에서 POI를 다시 불러왔습니다.');
    });
    $('#import-button').addEventListener('click', () => $('#file-input').click());
    $('#file-input').addEventListener('change', async (event) => {
        const file = event.target.files[0];
        if (!file) return;
        try {
            setImportBusy(true);
            const form = new FormData();
            form.append('file', file);
            const result = await request('/api/pois/import/preview', { method: 'POST', body: form });
            selectedImportFile = file;
            showImportPreview(file, result.resultData.validCount);
        } catch (error) {
            const invalidRows = error.invalidRows?.length ? ` 오류 행: ${error.invalidRows.join(', ')}` : '';
            notify(`${error.message}${invalidRows}`, true);
            clearImportPreview();
        } finally {
            setImportBusy(false);
            event.target.value = '';
        }
    });
    $('#import-confirm-button').addEventListener('click', async () => {
        if (!selectedImportFile) return;
        try {
            setImportBusy(true);
            const form = new FormData();
            form.append('file', selectedImportFile);
            const result = await request('/api/pois/import', { method: 'POST', body: form });
            await loadPois();
            notify(result.message);
            clearImportPreview();
        } catch (error) {
            notify(error.message, true);
        } finally {
            setImportBusy(false);
        }
    });
    $('#import-cancel-button').addEventListener('click', clearImportPreview);

    map.on('click', (event) => {
        if (!isPoiAddMode) return;
        setPoiAddMode(false);
        createPoiAt(event.latlng.lat, event.latlng.lng);
    });
    window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && isPoiAddMode) {
            setPoiAddMode(false);
            notify('POI 추가 모드를 취소했습니다.');
        }
    });

    trackPosition();
    loadPois();
})();
</script>
</body>
</html>
